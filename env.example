# Senbon Garden — environment template
# Copy to .env.local and fill in.

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://senbon.ch"

# --- Guestbook ---
# Self-hosted guestbook API (Docker stack at /srv/senbon-guestbook on the VPS).
# Both values are server-only — never prefix them with NEXT_PUBLIC_, since the
# token grants write access. Leave either blank to render the "paused" notice.
GUESTBOOK_API_URL="https://senbon.152.53.185.247.sslip.io"
GUESTBOOK_API_TOKEN=""
