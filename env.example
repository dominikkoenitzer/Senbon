# Senbon Garden — environment template
# Copy to .env.local and fill in.

# --- Database ( / ) ---
# Vercel's  integration provides these automatically in production.
DATABASE_URL=""
_URL=""
# Non-pooled connection (used for one-shot writes).
DATABASE_URL_UNPOOLED=""

# --- Admin ---
# Token gating the moderation panel at /admin and PATCH/DELETE on the API.
GUESTBOOK_ADMIN_TOKEN="super-secret-token-change-me"

# --- Privacy ---
# Keyed HMAC salt for hashing client IPs. Without it, IPs are sha256'd (still
# one-way, but trivially reversible for known IP ranges). Set to any high-
# entropy random string in production.
IP_HASH_SALT=""

# --- Guestbook behavior ---
# Set to "false" to require moderation before new entries appear publicly.
GUESTBOOK_AUTO_APPROVE="true"
# Set to "true" to skip the 30-second per-IP rate limit. Useful in dev.
GUESTBOOK_DISABLE_RATE_LIMIT="false"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://senbon.ch"
